---
import { Picture } from "astro:assets";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
import Scene from "./Scene.astro";
---

<Scene id="garden-formal" image={invitationAssets.gardenFormal.scene} minHeight="min-h-svh">
  <div class="mx-auto w-full max-w-5xl">
    <h2 class="text-sparkle text-center font-script text-7xl sm:text-8xl">{invitation.gardenFormal.title}</h2>
    <dl class="mx-auto mt-8 grid max-w-4xl gap-8 text-center sm:grid-cols-2">
      {invitation.gardenFormal.guidance.map((item) => (
        <div>
          <dt class="font-sans text-sm font-semibold tracking-[0.2em] text-invitation-gold uppercase">{item.label}</dt>
          <dd class="mt-2 font-serif text-lg italic">{item.description}</dd>
        </div>
      ))}
    </dl>
    <Picture
      src={invitationAssets.gardenFormal.lineup.src}
      alt={invitationAssets.gardenFormal.lineup.alt}
      formats={["avif", "webp"]}
      widths={[480, 768, 1024, 1440]}
      sizes="(min-width: 1280px) 1152px, calc(100vw - 3rem)"
      loading="lazy"
      class="mx-auto mt-10 w-full max-w-4xl object-contain"
    />
  </div>
</Scene>