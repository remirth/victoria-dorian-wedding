---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  image: {
    src: ImageMetadata;
    alt: string;
    position?: `${number}% ${number}%`;
  };
  natural?: boolean;
  eager?: boolean;
  class?: string;
}

const { id, image, natural = false, eager = false, class: className } = Astro.props;
---

<section
  id={id}
  class:list={[
    "relative isolate flex overflow-hidden bg-invitation-navy text-invitation-ivory",
    natural ? "min-h-svh py-20 sm:py-28" : "min-h-svh items-center py-16 sm:py-24",
    className,
  ]}
>
  <Picture
    src={image.src}
    alt={image.alt}
    formats={["avif", "webp"]}
    widths={[480, 768, 1024, 1440, 1920]}
    sizes="100vw"
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
    class="absolute inset-0 -z-20 size-full object-cover"
    style={`object-position: ${image.position ?? "50% 50%"}`}
  />
  <div class="absolute inset-0 -z-10 bg-linear-to-b from-black/40 via-black/55 to-black/75"></div>
  <div class="mx-auto w-full max-w-7xl px-6 sm:px-10 lg:px-16">
    <slot />
  </div>
</section>
