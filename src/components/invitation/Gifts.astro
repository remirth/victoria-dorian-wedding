---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="gifts" image={invitationAssets.gifts.couple} motion="wipe">
  <div class=" h-[80svh]" data-reveal="body">
    <h2 class="text-sparkle font-script text-7xl sm:text-8xl text-center mb-[35svh]">{invitation.gifts.title}</h2>
    <div class="mt-7 space-y-5 font-serif text-lg leading-relaxed italic max-w-xl place-self-center">
      {invitation.gifts.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</Scene>
