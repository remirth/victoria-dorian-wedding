---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="gifts" image={invitationAssets.gifts.couple}>
  <div class="max-w-xl rounded-sm bg-invitation-berry/75 p-7 sm:p-10">
    <h2 class="font-script text-7xl text-invitation-champagne sm:text-8xl">{invitation.gifts.title}</h2>
    <div class="mt-7 space-y-5 font-serif text-lg leading-relaxed italic">
      {invitation.gifts.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</Scene>
