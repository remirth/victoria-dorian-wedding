---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="parking-and-directions" image={invitationAssets.parking.couple}>
  <div class="max-w-xl">
    <h2 class="text-sparkle font-script text-6xl leading-none sm:text-7xl">
      {invitation.parking.title}
    </h2>
    <div class="mt-8 space-y-5 font-serif text-lg leading-relaxed italic">
      {invitation.parking.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</Scene>
