---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="closing-message" image={invitationAssets.closing.couple} class="text-center" motion="light">
  <div class="mx-auto max-w-4xl" data-reveal="light">
    <h2 class="text-sparkle font-script text-6xl leading-none sm:text-8xl">
      <span class="text-invitation-champagne break-all">#TheBrightestMix</span>
    </h2>
    <p class="mt-2 font-serif text-3xl text-invitation-gold italic sm:text-4xl">begins here,</p>
    <p class="mt-6 font-serif text-2xl text-invitation-gold italic sm:text-3xl">{invitation.closing.message}</p>
  </div>
</Scene>
