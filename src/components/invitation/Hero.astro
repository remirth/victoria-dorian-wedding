---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="invitation" image={invitationAssets.hero.couple} eager class="text-center">
  <div class="mx-auto flex max-w-4xl flex-col items-center">
    <p class="font-sans text-xs font-semibold tracking-[0.3em] uppercase sm:text-sm">
      {invitation.hero.eyebrow.map((line) => <span class="block">{line}</span>)}
    </p>
    <h1 class="mt-8 font-script text-7xl leading-[0.78] text-invitation-champagne drop-shadow-lg sm:text-8xl lg:text-9xl">
      <span class="block">{invitation.couple.bride}</span>
      <span class="my-2 block text-5xl text-invitation-gold sm:text-6xl">&amp;</span>
      <span class="block">{invitation.couple.groom}</span>
    </h1>
    <p class="mt-10 font-sans text-lg font-medium tracking-[0.22em] text-invitation-gold sm:text-xl">
      <time datetime={invitation.weddingDate}>{invitation.numericDate}</time>
    </p>
    <p class="mt-4 font-serif text-lg italic sm:text-xl">
      <time datetime={invitation.weddingDate}>{invitation.displayDate} | {invitation.displayTime}</time>
      <span class="mt-1 block">{invitation.venue.shortName}</span>
    </p>
  </div>
</Scene>
