---
import Scene from "./Scene.astro";
import { invitation } from "../../content/invitation";
import { invitationAssets } from "../../content/invitation-assets";
---

<Scene id="frequently-asked-questions" image={invitationAssets.faq.couple} natural motion="editorial">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-sparkle text-center font-script text-6xl leading-none sm:text-8xl" data-reveal="body">
      {invitation.faq.title}
    </h2>
    <ol class="mt-12 space-y-8" data-stagger="faq">
      {invitation.faq.items.map((item) => (
        <li class="border-l-2 border-invitation-gold bg-black/45 p-6 sm:p-8" data-stagger-item>
          <h3 class="font-serif text-xl font-semibold text-invitation-champagne sm:text-2xl">
            {item.question}
          </h3>
          <p class="mt-3 font-serif text-base leading-relaxed italic sm:text-lg">{item.answer}</p>
        </li>
      ))}
    </ol>
  </div>
</Scene>
