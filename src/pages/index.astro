---
import { getImage } from "astro:assets";
import Closing from "../components/invitation/Closing.astro";
import Directions from "../components/invitation/Directions.astro";
import DressCode from "../components/invitation/DressCode.astro";
import EnvelopeIntro from "../components/invitation/EnvelopeIntro";
import Faq from "../components/invitation/Faq.astro";
import GardenFormal from "../components/invitation/GardenFormal.astro";
import Gifts from "../components/invitation/Gifts.astro";
import Hero from "../components/invitation/Hero.astro";
import Parking from "../components/invitation/Parking.astro";
import Rsvp from "../components/invitation/Rsvp.astro";
import Story from "../components/invitation/Story.astro";
import Venue from "../components/invitation/Venue.astro";
import WeddingParty from "../components/invitation/WeddingParty.astro";
import { invitationAssets } from "../content/invitation-assets";
import Layout from "../layouts/Layout.astro";

const title = "Victoria & Dorian | Wedding Invitation";
const description =
  "Join Victoria and Dorian for their wedding at Narra Hill, Batangas on 29 September 2026.";
const canonical = new URL("/", Astro.site);
const socialImageAsset = await getImage({
  src: invitationAssets.hero.couple.src,
  width: 1200,
  height: 630,
  fit: "cover",
  position: "center",
  format: "jpeg",
});
const envelopeImageAsset = await getImage({
  src: invitationAssets.hero.couple.src,
  width: 480,
  format: "webp",
});
const socialImage = new URL(socialImageAsset.src, Astro.site);
---

<Layout {title} {description} {canonical} {socialImage}>
  <script is:inline>
    document.documentElement.dataset.invitationEnhanced = "true";
    let invitationOpened = location.hash === "#invitation";
    try {
      invitationOpened ||= sessionStorage.getItem("victoria-dorian-invitation-opened") === "true";
    } catch {}
    if (invitationOpened) document.documentElement.dataset.invitationOpened = "true";
  </script>
  <EnvelopeIntro heroImageSrc={envelopeImageAsset.src} client:load />
  <main data-invitation-document>
    <Hero />
    <Story />
    <Venue />
    <Parking />
    <DressCode />
    <GardenFormal />
    <WeddingParty />
    <Rsvp />
    <Gifts />
    <Faq />
    <Closing />
    <Directions />
  </main>
  <script>
    import "../scripts/scene-motion";
  </script>
</Layout>
